{
  "name": "@nullpinter/satteri-extended-table",
  "version": "0.1.3",
  "description": "Satteri plugin for extended table colspan and rowspan syntax",
  "keywords": [
    "markdown",
    "mdx",
    "satteri",
    "satteri-plugin"
  ],
  "homepage": "https://github.com/baka-gourd/satteri-plugins",
